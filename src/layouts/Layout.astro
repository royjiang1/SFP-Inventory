---
const { title } = Astro.props;
const currentPath = Astro.url.pathname.toLowerCase();

const navLinks = [
  { name: 'HOME', url: '/' },
  { name: 'CISCO', url: '/products/cisco' },
  { name: 'HUAWEI', url: '/products/huawei' },
  { name: 'FINISAR', url: '/products/finisar' },
  { name: 'BROCADE', url: '/products/brocade' },
  { name: 'HPE', url: '/products/hpe' },
  { name: 'NOKIA', url: '/products/nokia' },
  { name: 'JUNIPER', url: '/products/juniper' },
];

const brands = [
  'Acacia', 'Arista', 'Avago', 'Avaya', 'Ciena', 'Dell', 'Ericsson', 
  'Extreme Networks', 'F5', 'Fortinet', 'H3C', 'Hisense', 'Inno Light', 
  'Intel', 'JDSU', 'Mellanox', 'Raisecom', 'Solarflare', 'Source', 'ZTE', 'Others'
];
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | H-COM</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Poppins', 'sans-serif'] },
                    colors: {
                        'h-blue': '#1D4ED8', 'h-gray': '#F3F4F6', 'h-black': '#111827', 'h-subtle': '#6B7280',
                    }
                }
            }
        }
    </script>
    <style is:global>
        body { font-family: 'Poppins', sans-serif; background-color: white; color: #111827; scroll-behavior: smooth; }
        .nav-link { position: relative; transition: color 0.3s ease; }
        .nav-link::after {
            content: ''; position: absolute; width: 0; height: 2px; bottom: -4px; left: 0;
            background-color: #1D4ED8; transition: width 0.3s ease;
        }
        .nav-link:hover::after, .nav-link.active::after { width: 100%; }
        
        /* 找回下拉品牌下划线 */
        .dropdown-brand-link { position: relative; transition: all 0.3s ease; }
        .dropdown-brand-link::after {
            content: ''; position: absolute; width: 0; height: 1.5px; bottom: 0; left: 0;
            background-color: #1D4ED8; transition: width 0.3s ease;
        }
        .dropdown-brand-link:hover::after { width: 100%; }
    </style>
</head>
<body class="antialiased">
    <header class="bg-white sticky top-0 z-50 border-b border-gray-100 shadow-sm px-4 sm:px-6 lg:px-8 py-4">
        <nav class="max-w-7xl mx-auto flex items-center justify-between">
            <div class="flex items-center gap-10">
                <a href="/" class="text-3xl font-extrabold text-h-blue tracking-tighter">H-COM</a>
                <div class="hidden lg:flex items-center gap-9 text-[13px] font-bold uppercase tracking-tight">
                    {navLinks.map(link => (
                        <a href={link.url} class={`nav-link hover:text-h-blue transition-colors ${currentPath.includes(link.name.toLowerCase()) ? 'active text-h-blue' : 'text-h-subtle'}`}>
                            {link.name}
                        </a>
                    ))}
                    <div class="relative group py-2">
                        <button class="nav-link text-h-subtle flex items-center gap-1 hover:text-h-blue group-hover:text-h-blue uppercase">
                            MORE 
                            <svg class="w-2.5 h-2.5 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div class="absolute left-0 mt-2 w-[520px] bg-white border border-gray-100 shadow-2xl rounded-2xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 p-6 grid grid-cols-3 gap-x-4 gap-y-2">
                            {brands.map(brand => (
                                <a href={`/products/${brand.toLowerCase()}`} class="dropdown-brand-link text-[13px] font-bold text-gray-500 hover:text-h-blue py-1">{brand}</a>
                            ))}
                        </div>
                    </div>
                </div>
            </div>
            <div class="relative group">
                <svg class="w-4 h-4 absolute left-4 top-1/2 -translate-y-1/2 text-h-subtle" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                <input type="search" placeholder="Search PN..." class="bg-h-gray border border-transparent rounded-full pl-11 pr-4 py-2 text-sm w-44 md:w-60 focus:w-72 transition-all duration-300 focus:bg-white focus:border-h-blue outline-none">
            </div>
        </nav>
    </header>

    <slot />

    <footer class="bg-h-black text-gray-400 mt-32 pt-20 pb-10 px-4 sm:px-6 lg:px-8">
        <div class="max-w-7xl mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
                <div>
                    <span class="text-3xl font-extrabold text-white tracking-tighter mb-6 block">H-COM</span>
                    <p class="text-[13px] leading-relaxed">Global distributor of professional network components. Specializing in SFP, Switches, and optical transceivers.</p>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-6 uppercase text-[11px] tracking-widest">Quick Links</h4>
                    <ul class="space-y-4 text-[13px] font-medium">
                        <li><a href="/" class="hover:text-white transition">Home</a></li>
                        <li><a href="#" class="hover:text-white transition">About Us</a></li>
                        <li><a href="#" class="hover:text-white transition">Terms of Service</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-6 uppercase text-[11px] tracking-widest">Top Brands</h4>
                    <ul class="space-y-4 text-[13px] font-medium">
                        <li><a href="/products/cisco" class="hover:text-white transition">Cisco Systems</a></li>
                        <li><a href="/products/huawei" class="hover:text-white transition">Huawei</a></li>
                        <li><a href="/products/juniper" class="hover:text-white transition">Juniper Networks</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="text-white font-bold mb-6 uppercase text-[11px] tracking-widest">Connect</h4>
                    <p class="text-[13px] mb-4 font-semibold text-white">Hunan Zhaoyong Communication Tech Co., Ltd.</p>
                    <div class="space-y-3 mb-6">
