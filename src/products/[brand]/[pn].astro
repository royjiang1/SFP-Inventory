---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

// 强制开启预渲染（静态生成）
export const prerender = true;

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts.map(entry => ({
    params: { 
      // 确保这里的 brand 和 pn 与文件夹名字一致
      brand: entry.data.brand.toLowerCase(), 
      pn: entry.data.pn 
    },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.pn} | ${entry.data.brand} - H-COM`}>
  <div class="max-w-7xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <div class="bg-gray-50 rounded-3xl p-8 flex items-center justify-center border border-gray-100">
        <img 
          src={`/images/products/${entry.data.brand.toLowerCase()}/${entry.data.pn}.jpg`} 
          alt={entry.data.model}
          class="w-full h-auto shadow-sm rounded-lg"
          onerror="this.src='https://placehold.co/600x600/f3f4f6/111827?text=Product+Image'"
        />
      </div>

      <div>
        <nav class="flex mb-4 text-xs font-bold uppercase tracking-widest text-blue-600">
          <a href="/" class="hover:underline">Inventory</a>
          <span class="mx-2 text-gray-300">/</span>
          <span>{entry.data.brand}</span>
        </nav>
        
        <h1 class="text-4xl font-extrabold text-gray-900 mb-2">{entry.data.pn}</h1>
        <p class="text-xl text-gray-500 mb-8 font-medium">{entry.data.model}</p>

        <div class="text-3xl font-black text-red-600 mb-10">US$ {entry.data.price}</div>

        <div class="grid grid-cols-2 gap-y-6 gap-x-4 border-t border-gray-100 pt-8">
          <div>
            <dt class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Speed</dt>
            <dd class="text-gray-900 font-semibold">{entry.data.speed}</dd>
          </div>
          <div>
            <dt class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Reach</dt>
            <dd class="text-gray-900 font-semibold">{entry.data.reach}</dd>
          </div>
          <div>
            <dt class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Wavelength</dt>
            <dd class="text-gray-900 font-semibold">{entry.data.wavelength}</dd>
          </div>
          <div>
            <dt class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">Connector</dt>
            <dd class="text-gray-900 font-semibold">{entry.data.connector}</dd>
          </div>
        </div>

        <div class="mt-12">
          <a href="https://wa.me/8617722444464" target="_blank" class="bg-black text-white px-8 py-4 rounded-full font-bold text-sm hover:bg-blue-600 transition-colors inline-flex items-center gap-3">
            <i class="fab fa-whatsapp text-lg"></i> INQUIRY NOW
          </a>
        </div>
      </div>
    </div>

    <div class="mt-20 prose prose-slate max-w-none border-t border-gray-100 pt-10">
      <h3 class="text-xl font-bold mb-6">Product Description</h3>
      <Content />
    </div>
  </div>
</Layout>
