---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts.map(entry => ({
    params: { brand: entry.data.brand.toLowerCase(), pn: entry.data.pn },
    props: { entry, allProducts },
  }));
}

const { entry, allProducts } = Astro.props;
const { Content } = await entry.render();

/** * 【自动化图片探测逻辑】
 * 这行代码会扫描 public/images/products 下的所有图片
 * 我们筛选出路径中包含当前品牌和当前 PN 的所有图片
 **/
const allImages = import.meta.glob('/public/images/products/**/*.{jpg,jpeg,png,webp}', { eager: true });
const productImages = Object.keys(allImages)
  .filter(path => {
    const fileName = path.split('/').pop()?.toLowerCase() || '';
    const brandPath = `/${entry.data.brand.toLowerCase()}/`;
    // 匹配规则：路径包含品牌名，且文件名以 PN 开头（例如 34060276.jpg 或 34060276 (2).jpg）
    return path.toLowerCase().includes(brandPath) && fileName.startsWith(entry.data.pn.toLowerCase());
  })
  .map(path => path.replace('/public', '')) // 转换成浏览器可访问的路径
  .sort(); // 排序确保主图（没有括号的）通常排在第一

// 如果没搜到图，给一个保底图
const displayImages = productImages.length > 0 ? productImages : ['https://placehold.co/600x600?text=No+Image'];

// Related Modules 逻辑保持不变
const relatedItems = allProducts
  .filter(p => p.data.brand === entry.data.brand && p.data.pn !== entry.data.pn)
  .slice(0, 4);
---

<Layout title={`${entry.data.pn} - H-COM`}>
  <div class="max-w-7xl mx-auto px-4 py-8">
    
    <nav class="flex mb-6 text-[11px] font-bold uppercase tracking-widest text-gray-400">
      <a href="/" class="hover:text-h-blue">HOME</a>
      <span class="mx-3">/</span>
      <a href={`/products/${entry.data.brand.toLowerCase()}`} class="hover:text-h-blue">{entry.data.brand}</a>
      <span class="mx-3 text-h-blue">/</span>
      <span class="text-gray-900">{entry.data.pn}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <div class="lg:col-span-7 space-y-4">
        <div class="relative overflow-hidden bg-gray-50 rounded-3xl border border-gray-100 group cursor-zoom-in">
           <img 
            id="mainDisplay"
            src={displayImages[0]} 
            alt={entry.data.pn}
            class="w-full h-[500px] object-contain transition-transform duration-500 group-hover:scale-125"
          />
        </div>

        {displayImages.length > 1 && (
          <div class="flex gap-4 flex-wrap">
            {displayImages.map((img) => (
              <button 
                onclick={`document.getElementById('mainDisplay').src='${img}'`}
                class="w-20 h-20 border border-gray-200 hover:border-h-blue rounded-xl overflow-hidden transition-all focus:border-h-blue focus:border-2"
              >
                <img src={img} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <div class="lg:col-span-5">
        <h1 class="text-5xl font-black text-gray-900 tracking-tighter mb-2">{entry.data.pn}</h1>
        <p class="text-xl text-gray-500 font-medium mb-6">{entry.data.model}</p>
        
        <div class="text-3xl font-black text-red-600 mb-10">US$ {entry.data.price}</div>

        <div class="grid grid-cols-2 gap-y-8 gap-x-4 border-y border-gray-100 py-10 mb-10">
          <div>
            <dt class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">Speed</dt>
            <dd class="text-lg font-bold text-gray-900">{entry.data.speed}</dd>
          </div>
          <div>
            <dt class="text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-2">Reach</dt>
            <dd class="text-lg font-bold text-gray-900">{entry.data.reach}</dd>
          </div>
        </div>

        <a href={`https://wa.me/8617722444464?text=Inquiry for ${entry.data.pn}`} class="w-full bg-h-blue text-white py-5 rounded-2xl font-black text-center block hover:bg-blue-700 transition-all shadow-lg shadow-blue-100 uppercase tracking-widest">
           INQUIRY VIA WHATSAPP
        </a>
      </div>
    </div>

    {relatedItems.length > 0 && (
      <div class="mt-32">
        <h3 class="text-2xl font-black mb-10 tracking-tight italic uppercase border-b-2 border-black inline-block">Related Modules</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
          {relatedItems.map(item => (
            <a href={`/products/${item.data.brand.toLowerCase()}/${item.data.pn}`} class="group">
               <div class="aspect-square bg-gray-50 rounded-2xl mb-4 overflow-hidden border border-gray-100">
                  <img 
                    src={`/images/products/${item.data.brand.toLowerCase()}/${item.data.pn}.jpg`} 
                    class="w-full h-full object-contain p-4 group-hover:scale-110 transition-transform duration-500" 
                  />
               </div>
               <p class="text-[10px] font-bold text-h-blue uppercase">{item.data.brand}</p>
               <h4 class="font-black text-gray-900 group-hover:text-h-blue transition-colors">{item.data.pn}</h4>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</Layout>
