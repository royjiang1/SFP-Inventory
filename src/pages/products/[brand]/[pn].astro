---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const allProducts = await getCollection('products');
---

<Layout title="H-COM | Professional SFP & Optical Transceivers Inventory">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-20">
      <div class="inline-block px-4 py-1 mb-6 rounded-full bg-blue-50 text-h-blue text-[11px] font-bold tracking-[0.2em] uppercase border border-blue-100 animate-pulse">
        Direct Inventory • Tested Quality • Global Shipping
      </div>
      <h1 class="text-5xl md:text-6xl font-black text-h-black tracking-tighter mb-6 uppercase">
        SFP <span class="text-h-blue italic underline decoration-4 underline-offset-8 decoration-blue-100">INVENTORY</span>
      </h1>
      <p class="text-h-subtle max-w-2xl mx-auto text-sm font-medium leading-relaxed">
        Trusted global distributor of high-performance network components. Original Huawei, Cisco, and Finisar modules ready for express dispatch.
      </p>
    </div>

    <section>
      <div class="flex items-center justify-between mb-10 border-b border-gray-100 pb-5">
        <h2 class="text-xl font-black text-h-black tracking-tight uppercase">Latest Stock</h2>
        <span class="text-xs text-h-blue font-bold tracking-widest bg-blue-50 px-3 py-1 rounded-lg">{allProducts.length} PRODUCTS</span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8 md:gap-10">
        {allProducts.map(product => (
          <div class="group bg-white rounded-3xl border border-gray-100 p-5 hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
            <a href={`/products/${product.data.brand.toLowerCase()}/${product.data.pn}`}>
              <div class="aspect-square bg-h-gray rounded-2xl mb-6 overflow-hidden flex items-center justify-center p-2 relative">
                 <img 
                  src={`/images/products/${product.data.brand.toLowerCase()}/${product.data.pn}.jpg`} 
                  alt={product.data.model}
                  class="max-w-[85%] max-h-[85%] object-contain group-hover:scale-110 transition-transform duration-700 drop-shadow-md"
                  onerror="this.src='https://placehold.co/400x400/f3f4f6/111827?text=SFP'"
                />
              </div>
              <span class="text-[10px] font-black text-h-blue uppercase mb-2 block tracking-[0.2em] opacity-80">{product.data.brand}</span>
              <h3 class="font-black text-h-black mb-1 group-hover:text-h-blue transition-colors line-clamp-1 text-base uppercase tracking-tight">{product.data.pn}</h3>
              <p class="text-[11px] text-h-subtle font-bold mb-5 line-clamp-1 italic uppercase">{product.data.model}</p>
              
              <div class="flex items-center justify-between mt-auto">
                <div class="text-lg font-black text-red-600">US$ {product.data.price}</div>
                <div class="inline-flex items-center gap-2 text-[10px] font-bold text-h-black group-hover:text-h-blue transition-all group-hover:gap-4">
                  VIEW <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
                </div>
              </div>
            </a>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>
