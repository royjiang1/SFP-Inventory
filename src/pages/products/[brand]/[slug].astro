---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(entry => {
    const [brand, ...slugParts] = entry.slug.split('/');
    const slug = slugParts.join('/') || brand;
    return {
      params: { 
        brand: brand.toLowerCase(), 
        slug: slug 
      },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

// 路径与 SEO 变量
const brandName = data.brand;
const productName = data.model;
const partNumber = data.pn;
const siteUrl = "https://h-com.com"; // 替换为你的真实域名
const brandFolder = brandName.toLowerCase();
const mainImagePath = `/images/products/${brandFolder}/${partNumber}.jpg`;

// JSON-LD 结构化数据 (SEO 杀手锏)
const jsonLd = {
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": `${brandName} ${productName}`,
  "image": [`${siteUrl}${mainImagePath}`],
  "description": `Original ${brandName} ${partNumber} module. ${data.speed}, ${data.reach}. Tested and functional.`,
  "sku": partNumber,
  "brand": {
    "@type": "Brand",
    "name": brandName
  },
  "offers": {
    "@type": "Offer",
    "url": `${siteUrl}/${brandFolder}/${entry.slug}`,
    "priceCurrency": "USD",
    "price": data.price,
    "availability": "https://schema.org/InStock",
    "itemCondition": data.condition === "New" ? "https://schema.org/NewCondition" : "https://schema.org/UsedCondition"
  }
};

const whatsappNumber = "8617722444464";
const whatsappLink = `https://wa.me/${whatsappNumber}?text=Inquiry%20about%20${brandName}%20${partNumber}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{brandName} {partNumber} | {productName} - H-COM</title>
    <meta name="description" content={`Buy original ${brandName} ${partNumber} (${productName}). ${data.speed} ${data.wavelength} ${data.reach}. Global shipping available.`} />
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <style is:global>
        body { font-family: 'Poppins', sans-serif; background-color: white; color: #111827; }
        .nav-link { position: relative; transition: color 0.3s ease; }
        .nav-link::after {
            content: ''; position: absolute; width: 0; height: 2px;
            bottom: -4px; left: 0; background-color: #1D4ED8;
            transition: width 0.3s ease;
        }
        .nav-link:hover::after, .nav-link.active::after { width: 100%; }
        
        .zoom-container { overflow: hidden; border-radius: 0.75rem; background-color: #F3F4F6; cursor: zoom-in; }
        .zoom-container img { transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1); display: block; }
        .zoom-container:hover img { transform: scale(1.08); }

        .dropdown-brand-link { position: relative; font-size: 14px; font-weight: 600; color: #6B7280; text-transform: uppercase; transition: all 0.3s ease; }
        .dropdown-brand-link:hover { color: #1D4ED8; }
    </style>
</head>
<body class="antialiased flex flex-col min-h-screen">

    <header class="bg-white sticky top-0 z-50 border-b border-gray-100 shadow-sm">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
            <div class="flex items-center gap-10">
                <a href="/" class="text-3xl font-extrabold text-h-blue tracking-tighter">H-COM</a>
                <div class="hidden lg:flex items-center gap-9 text-[14px] font-semibold text-h-subtle uppercase tracking-tight">
                    <a href="/" class="nav-link">HOME</a>
                    <a href="/cisco" class="nav-link">CISCO</a>
                    <a href="/huawei" class="nav-link active text-h-blue">HUAWEI</a>
                    <a href="/nokia" class="nav-link">NOKIA</a>
                    </div>
            </div>
            <div class="relative group">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-h-subtle text-sm"></i>
                <input type="search" placeholder="Search PN..." class="bg-h-gray rounded-full pl-11 pr-4 py-2 text-sm w-48 focus:w-64 transition-all outline-none">
            </div>
        </nav>
    </header>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 flex-grow">
        <nav class="flex mb-10 text-[11px] font-bold text-h-subtle uppercase tracking-[0.1em]">
            <ol class="inline-flex items-center space-x-2">
                <li><a href="/" class="hover:text-h-black">Home</a></li>
                <li class="text-gray-300">/</li>
                <li><a href={`/${brandFolder}`} class="hover:text-h-black">{brandName}</a></li>
                <li class="text-gray-300">/</li>
                <li class="text-h-black">{partNumber}</li>
            </ol>
        </nav>

        <div class="lg:grid lg:grid-cols-12 lg:gap-x-16">
            <div class="lg:col-span-7 mb-12 lg:mb-0">
                <div class="zoom-container mb-6">
                    <img id="main-image" src={mainImagePath} alt={`${brandName} ${partNumber} Main View`} class="w-full h-auto" onerror="this.src='https://placehold.co/1000x750?text=Image+Coming+Soon'" />
                </div>
                <div class="grid grid-cols-5 gap-4" id="thumb-strip">
                    <img src={mainImagePath} onclick="changeImage(this)" class="cursor-pointer rounded-lg border-2 border-h-blue transition-all" />
                    </div>
            </div>

            <div class="lg:col-span-5">
                <div class="mb-4">
                    <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 uppercase tracking-widest border border-amber-100">
                        {data.condition}
                    </span>
                </div>
                <h1 class="text-4xl font-bold text-h-black mb-2 tracking-tight">{brandName} {productName}</h1>
                <p class="text-xl text-h-blue font-semibold mb-6">P/N: {partNumber}</p>

                <div class="space-y-6 mb-10 pb-8 border-b border-gray-100">
                    <div class="prose prose-sm max-w-none text-h-subtle leading-relaxed">
                        <Content />
                    </div>
                    <div class="mt-4 flex items-baseline gap-3">
                        <span class="text-3xl font-extrabold text-red-600">USD ${data.price}</span>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-y-4 gap-x-8 text-[13px]">
                        <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-h-subtle">Speed:</span><span class="font-bold">{data.speed}</span></div>
                        <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-h-subtle">Reach:</span><span class="font-bold">{data.reach}</span></div>
                        <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-h-subtle">Wavelength:</span><span class="font-bold">{data.wavelength}</span></div>
                        <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-h-subtle">Connector:</span><span class="font-bold">{data.connector}</span></div>
                    </div>
                </div>

                <div class="mb-10">
                    <a href={whatsappLink} target="_blank" class="flex items-center justify-center gap-3 w-full bg-[#25D366] text-white py-4 rounded-xl font-bold hover:scale-[1.02] transition-transform shadow-lg shadow-green-100">
                        <i class="fa-brands fa-whatsapp text-xl"></i> Inquiry via WhatsApp
                    </a>
                </div>
            </div>
        </div>
    </main>

    <footer class="bg-h-black text-gray-400 mt-32 pt-20 pb-10 px-4">
        <div class="max-w-7xl mx-auto text-center border-t border-gray-800 pt-10">
            <p class="text-[11px] font-medium uppercase tracking-widest">&copy; {new Date().getFullYear()} Hunan Zhaoyong Communication Technology Co., Ltd.</p>
        </div>
    </footer>

    <script is:inline>
        function changeImage(thumbnail) {
            const mainImg = document.getElementById('main-image');
            mainImg.src = thumbnail.src;
            const thumbs = document.querySelectorAll('#thumb-strip img');
            thumbs.forEach(img => img.classList.replace('border-h-blue', 'border-transparent'));
            thumbnail.classList.replace('border-transparent', 'border-h-blue');
        }
    </script>
</body>
</html>
