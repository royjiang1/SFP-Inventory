---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts.map(entry => ({
    params: { brand: entry.data.brand.toLowerCase(), pn: entry.data.pn },
    props: { entry, allProducts },
  }));
}

const { entry, allProducts } = Astro.props;
const { Content } = await entry.render();

const metaDescription = `Professional ${entry.data.brand} ${entry.data.model} (${entry.data.pn}). Features ${entry.data.speed} speed, ${entry.data.reach} reach. Original quality with 1-year warranty.`;

const allImages = import.meta.glob('/public/images/products/**/*.{jpg,jpeg,png,webp}', { eager: true });
const productImages = Object.keys(allImages)
  .filter(path => {
    const fileName = path.split('/').pop()?.toLowerCase() || '';
    const brandPath = `/${entry.data.brand.toLowerCase()}/`;
    return path.toLowerCase().includes(brandPath) && fileName.startsWith(entry.data.pn.toLowerCase());
  })
  .map(path => path.replace('/public', ''))
  .sort();

const displayImages = productImages.length > 0 ? productImages : ['https://placehold.co/600x600?text=No+Image'];

const relatedItems = allProducts
  .filter(p => p.id !== entry.id)
  .map(p => {
    let score = 0;
    if (p.data.brand === entry.data.brand) score += 10;
    if (p.data.speed === entry.data.speed) score += 5;
    return { ...p, score };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 8);

const originalPrice = (parseFloat(entry.data.price) * 1.5).toFixed(2);
const shareUrl = Astro.url.href;
const messengerUrl = "https://m.me/61556808129251"; 
---

<Layout title={`${entry.data.brand} ${entry.data.pn} - H-COM`} description={metaDescription}>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <nav aria-label="Breadcrumb" class="flex mb-8 text-[11px] font-bold uppercase tracking-widest text-gray-400">
        <a href="/" class="hover:text-blue-600 transition-colors">HOME</a>
        <span class="mx-3">/</span>
        <a href={`/products/${entry.data.brand.toLowerCase()}`} class="hover:text-blue-600 transition-colors">{entry.data.brand}</a>
        <span class="mx-3 text-blue-600">/</span>
        <span class="text-gray-900" aria-current="page">{entry.data.pn}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-7 space-y-4">
            <div class="relative overflow-hidden bg-white rounded-3xl border border-gray-100 group aspect-[6/5] flex items-center justify-center p-2">
                <img 
                    id="mainDisplay" 
                    src={displayImages[0]} 
                    alt={`${entry.data.brand} ${entry.data.pn}`} 
                    fetchpriority="high"
                    loading="eager"
                    class="max-w-full max-h-full object-contain transition-transform duration-500 group-hover:scale-105" 
                />
            </div>
            
            {displayImages.length > 1 && (
                <div class="flex gap-4 flex-wrap">
                    {displayImages.map((img) => (
                        <button 
                            onclick={`document.getElementById('mainDisplay').src='${img}'`} 
                            class="w-20 h-20 border border-gray-200 hover:border-blue-600 rounded-xl overflow-hidden transition-all bg-white p-1"
                        >
                            <img src={img} alt="Thumbnail" class="w-full h-full object-contain" loading="lazy" />
                        </button>
                    ))}
                </div>
            )}
        </div>

        <div class="lg:col-span-5">
            <div class="mb-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 uppercase tracking-widest border border-amber-100">
                    {entry.data.condition}
                </span>
            </div>
            <h1 class="text-4xl font-bold text-gray-900 mb-2 tracking-tight">{entry.data.brand} {entry.data.model}</h1>
            <p class="text-xl text-blue-700 font-semibold mb-6">P/N: {entry.data.pn}</p>

            <div class="space-y-6 mb-10 pb-8 border-b border-gray-100">
                <div class="text-gray-500 text-sm leading-relaxed prose prose-sm max-w-none">
                    <Content /> 
                </div>
                
                <div class="mt-4 flex items-baseline gap-3">
                    <span class="text-3xl font-extrabold text-red-600">USD ${entry.data.price}</span>
                    <span class="text-sm text-gray-400 line-through">${originalPrice}</span>
                </div>

                <div class="grid grid-cols-2 gap-y-4 gap-x-8 text-[13px]">
                    <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-gray-400">Speed:</span><span class="font-bold">{entry.data.speed}</span></div>
                    <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-gray-400">Reach:</span><span class="font-bold">{entry.data.reach}</span></div>
                    <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-gray-400">Wavelength:</span><span class="font-bold">{entry.data.wavelength}</span></div>
                    <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-gray-400">Connector:</span><span class="font-bold">{entry.data.connector}</span></div>
                </div>
            </div>

            <div class="mb-10">
                <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-4">Contact & Inquiry</p>
                <div class="flex flex-row gap-3">
                    <a href="https://wa.me/8617722444464" target="_blank" class="flex-1 flex items-center justify-center py-4 bg-[#25D366] text-white rounded-xl hover:shadow-lg transition-all">
                        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.067 2.877 1.215 3.076.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.938 3.659 1.435 5.63 1.436h.008c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                    </a>
                    <a href={messengerUrl} target="_blank" class="flex-1 flex items-center justify-center py-4 bg-[#0084FF] text-white rounded-xl hover:shadow-lg transition-all">
                        <svg class="w-6 h-6 fill-current" viewBox="0 0 24 24"><path d="M12 0C5.373 0 0 4.974 0 11.111c0 3.498 1.744 6.614 4.469 8.654V24l4.088-2.242c.1.028.201.053.303.078 1.022.256 2.087.396 3.14.396 6.627 0 12-4.974 12-11.111C24 4.974 18.627 0 12 0zm1.291 14.88l-3.048-3.253-5.947 3.253 6.542-6.957 3.125 3.253 5.87-3.253-6.542 6.957z"/></svg>
                    </a>
                    <a href="mailto:info@zhaoyongoptics.com" class="flex-1 flex items-center justify-center py-4 bg-gray-900 text-white rounded-xl hover:shadow-lg transition-all">
                        <svg class="w-6 h-6 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </a>
                </div>
            </div>

            <div class="mt-6 pt-4 border-t border-gray-200 flex flex-wrap items-center gap-3">
                <span class="text-sm font-medium text-gray-600">Share:</span>
                <div class="flex gap-4">
                    <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" class="text-gray-400 hover:text-[#1877f2] transition-colors">
                        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </div>

<section class="mt-24 border-t border-gray-100 pt-16 space-y-24">
  <div>
    <h2 class="text-2xl font-extrabold text-h-black tracking-tight mb-10 flex items-center gap-3">
      <span class="w-8 h-1 bg-h-blue rounded-full"></span>
      PURCHASE INFORMATION
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="p-6 rounded-2xl bg-white border border-gray-100 transition-all duration-300">
        <div class="mb-5 text-h-black">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21a3.745 3.745 0 01-3.068-.907 3.745 3.745 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.745 3.745 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-h-black mb-3">Authenticity Guaranteed</h3>
        <p class="text-sm text-h-subtle leading-relaxed">
          All products are original, sourced from reputable suppliers. Please verify part numbers for system compatibility before ordering.
        </p>
      </div>

      <div class="p-6 rounded-2xl bg-white border border-gray-100 transition-all duration-300">
        <div class="mb-5 text-h-black">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-h-black mb-3">Condition Disclosure</h3>
        <p class="text-sm text-h-subtle leading-relaxed">
          Used products may have minor cosmetic wear, but are fully functional. Contact us for photos if aesthetics are a concern.
        </p>
      </div>

      <div class="p-6 rounded-2xl bg-white border border-gray-100 transition-all duration-300">
        <div class="mb-5 text-h-black">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-h-black mb-3">Warranty & Return</h3>
        <ul class="text-sm text-h-subtle space-y-2">
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-gray-300 rounded-full"></span> New Modules: 1-Year Warranty
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-gray-300 rounded-full"></span> Used Modules: 3-Month Warranty
          </li>
          <li class="flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-gray-300 rounded-full"></span> 14-Day Return Policy
          </li>
        </ul>
      </div>

      <div class="p-6 rounded-2xl bg-white border border-gray-100 transition-all duration-300">
        <div class="mb-5 text-h-black">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.25 18.75a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM18.75 18.75a1.5 1.5 0 100-3 1.5 1.5 0 000 3zM4.5 12h11.25M18 12h2.25m-2.25 0a2.25 2.25 0 00-2.25-2.25H15M3 4.875C3 4.115 3.615 3.5 4.375 3.5h9.75c.76 0 1.375.615 1.375 1.375V15.75m-11.25-4.5h1.125m-1.125 0c-.76 0-1.375.615-1.375 1.375V15.75c0 .76.615 1.375 1.375 1.375h1.5m1.125-10.5a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0z"></path>
          </svg>
        </div>
        <h3 class="text-lg font-bold text-h-black mb-3">Shipping</h3>
        <ul class="text-sm text-h-subtle space-y-2">
          <li class="flex items-start gap-2">
            <span class="mt-1.5 w-1.5 h-1.5 bg-gray-300 rounded-full flex-shrink-0"></span> Standard: China Post
          </li>
          <li class="flex items-start gap-2 text-xs text-red-500 font-medium">
            <span class="mt-1.5 w-1.5 h-1.5 bg-red-400 rounded-full flex-shrink-0"></span> Import tax duties are not included.
          </li>
          <li class="flex items-start gap-2">
            <span class="mt-1.5 w-1.5 h-1.5 bg-gray-300 rounded-full flex-shrink-0"></span> Express: DHL, FedEx available
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div>
    <h2 class="text-[14px] font-bold text-blue-800 text-center uppercase tracking-[0.3em] mb-16">Related Modules</h2>
    {relatedItems.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {relatedItems.map(item => (
          <div class="group bg-white rounded-2xl border border-gray-100 p-5 hover:border-h-blue/30 hover:shadow-xl hover:-translate-y-1 transition-all duration-500">
            <a href={`/products/${item.data.brand.toLowerCase()}/${item.data.pn}`}>
              <div class="aspect-square bg-gray-50 rounded-xl mb-6 overflow-hidden flex items-center justify-center p-2">
                <img 
                  src={`/images/products/${item.data.brand.toLowerCase()}/${item.data.pn}.jpg`} 
                  alt={`${item.data.brand} ${item.data.pn}`}
                  class="max-w-full max-h-full object-contain group-hover:scale-110 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
              <span class="text-[10px] font-bold text-blue-700 uppercase mb-2 block tracking-widest">{item.data.brand}</span>
              <h3 class="font-extrabold text-gray-900 mb-1 group-hover:text-blue-700 transition-colors line-clamp-1">{item.data.pn}</h3>
              <div class="text-lg font-extrabold text-red-600 mb-6">US$ {item.data.price}</div>
              <div class="inline-flex items-center gap-2 text-[11px] font-bold text-gray-900 group-hover:gap-4 transition-all uppercase">
                VIEW MORE 
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </a>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-center text-gray-400 text-sm">More modules coming soon...</p>
    )}
  </div>
</section>
  </main>
</Layout>
