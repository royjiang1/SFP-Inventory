---
import { getCollection } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const allProducts = await getCollection('products');
  return allProducts.map(entry => ({
    params: { brand: entry.data.brand.toLowerCase(), pn: entry.data.pn },
    props: { entry, allProducts },
  }));
}

const { entry, allProducts } = Astro.props;
const { Content } = await entry.render();

// 1. 动态图片识别逻辑
const allImages = import.meta.glob('/public/images/products/**/*.{jpg,jpeg,png,webp}', { eager: true });
const productImages = Object.keys(allImages)
  .filter(path => {
    const fileName = path.split('/').pop()?.toLowerCase() || '';
    const brandPath = `/${entry.data.brand.toLowerCase()}/`;
    return path.toLowerCase().includes(brandPath) && fileName.startsWith(entry.data.pn.toLowerCase());
  })
  .map(path => path.replace('/public', ''))
  .sort();

const displayImages = productImages.length > 0 ? productImages : ['https://placehold.co/600x600?text=No+Image'];

// 2. 智能推荐逻辑 (Related Modules) - 4x2 布局 (共8个)
const relatedItems = allProducts
  .filter(p => p.id !== entry.id)
  .map(p => {
    let score = 0;
    if (p.data.brand === entry.data.brand) score += 10;
    if (p.data.speed === entry.data.speed) score += 5;
    if (p.data.reach === entry.data.reach) score += 2;
    return { ...p, score };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 8);

const originalPrice = (parseFloat(entry.data.price) * 1.5).toFixed(2); // 假设原价高50%

// 3. 社交与联系链接
const shareUrl = Astro.url.href;
const messengerUrl = "https://m.me/61556808129251"; 
---

<Layout title={`${entry.data.pn} - H-COM`}>
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    
    <nav class="flex mb-8 text-[11px] font-bold uppercase tracking-widest text-gray-400">
        <a href="/" class="hover:text-blue-600 transition-colors">HOME</a>
        <span class="mx-3">/</span>
        <a href={`/products/${entry.data.brand.toLowerCase()}`} class="hover:text-blue-600 transition-colors">{entry.data.brand}</a>
        <span class="mx-3 text-blue-600">/</span>
        <span class="text-gray-900">{entry.data.pn}</span>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
        <div class="lg:col-span-7 space-y-4">
            <div class="relative overflow-hidden bg-white rounded-3xl border border-gray-100 group">
                <img id="mainDisplay" src={displayImages[0]} alt={entry.data.pn} class="w-full h-[550px] object-contain transition-transform duration-500 group-hover:scale-110" />
            </div>
            {displayImages.length > 1 && (
                <div class="flex gap-4 flex-wrap">
                    {displayImages.map((img) => (
                        <button onclick={`document.getElementById('mainDisplay').src='${img}'`} class="w-20 h-20 border border-gray-200 hover:border-blue-600 rounded-xl overflow-hidden transition-all">
                            <img src={img} class="w-full h-full object-cover" />
                        </button>
                    ))}
                </div>
            )}
        </div>

        <div class="lg:col-span-5">
            <div class="mb-4">
                <span class="inline-flex items-center px-3 py-1 rounded-full text-[10px] font-bold bg-amber-50 text-amber-700 uppercase tracking-widest border border-amber-100">
                    {entry.data.condition}
                </span>
            </div>
            <h1 class="text-4xl font-bold text-gray-900 mb-2 tracking-tight">{entry.data.brand} {entry.data.model}</h1>
            <p class="text-xl text-blue-700 font-semibold mb-6">P/N: {entry.data.pn}</p>

            <div class="space-y-6 mb-10 pb-8 border-b border-gray-100">
                <div class="text-gray-500 text-sm leading-relaxed prose prose-sm max-w-none">
                    <Content /> </div>
                
                <div class="mt-4 flex items-baseline gap-3">
                    <span class="text-3xl font-extrabold text-red-600">USD ${entry.data.price}</span>
                    <span class="text-sm text-gray-400 line-through">${originalPrice}</span>
                </div>

                <div class="grid grid-cols-2 gap-y-4 gap-x-8 text-[13px]">
                    <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-gray-400">Speed:</span><span class="font-bold">{entry.data.speed}</span></div>
                    <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-gray-400">Reach:</span><span class="font-bold">{entry.data.reach}</span></div>
                    <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-gray-400">Wavelength:</span><span class="font-bold">{entry.data.wavelength}</span></div>
                    <div class="flex justify-between border-b border-gray-50 pb-2"><span class="text-gray-400">Connector:</span><span class="font-bold">{entry.data.connector}</span></div>
                </div>
            </div>

            <div class="mb-10">
                <p class="text-[11px] font-bold text-gray-400 uppercase tracking-widest mb-4">Contact & Inquiry</p>
                <div class="flex flex-row gap-3">
                    <a href="https://wa.me/8617722444464" target="_blank" class="flex-1 flex items-center justify-center py-4 bg-[#25D366] text-white rounded-xl hover:shadow-lg transition-all">
                        <i class="fa-brands fa-whatsapp text-xl"></i>
                    </a>
                    <a href={messengerUrl} target="_blank" class="flex-1 flex items-center justify-center py-4 bg-[#0084FF] text-white rounded-xl hover:shadow-lg transition-all">
                        <i class="fa-brands fa-facebook-messenger text-xl"></i>
                    </a>
                    <a href="mailto:info@zhaoyongoptics.com" class="flex-1 flex items-center justify-center py-4 bg-gray-900 text-white rounded-xl hover:shadow-lg transition-all">
                        <i class="fa-regular fa-envelope text-xl"></i>
                    </a>
                </div>
            </div>

            <div class="mt-6 pt-4 border-t border-gray-200 flex flex-wrap items-center gap-3">
                <span class="text-sm font-medium text-gray-600"><i class="fas fa-share-alt mr-1"></i> Share:</span>
                <div class="flex gap-4">
                    <a href={`https://www.facebook.com/sharer/sharer.php?u=${shareUrl}`} target="_blank" class="text-gray-400 hover:text-[#1877f2] text-xl transition-colors"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href={`https://twitter.com/intent/tweet?url=${shareUrl}`} target="_blank" class="text-gray-400 hover:text-black text-xl transition-colors"><i class="fa-brands fa-x-twitter"></i></a>
                    <a href={`https://t.me/share/url?url=${shareUrl}`} target="_blank" class="text-gray-400 hover:text-[#26A5E4] text-xl transition-colors"><i class="fa-brands fa-telegram"></i></a>
                    <a href="https://www.instagram.com/" target="_blank" class="text-gray-400 hover:text-[#E4405F] text-xl transition-colors"><i class="fa-brands fa-instagram"></i></a>
                </div>
            </div>
        </div>
    </div>

    <section class="mt-24 border-t border-gray-100 pt-16">
        <h2 class="text-[14px] font-bold text-blue-800 text-center uppercase tracking-[0.3em] mb-16">Purchase Information</h2>
        <div class="grid md:grid-cols-4 gap-12">
            <div class="space-y-4">
                <div class="flex items-center gap-3 text-blue-700">
                    <i class="fa-solid fa-gem text-xl"></i>
                    <h4 class="font-bold text-[15px] text-gray-900">Authenticity</h4>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed font-medium">100% original modules sourced from reputable manufacturers. Part numbers verified for compatibility.</p>
            </div>
            <div class="space-y-4">
                <div class="flex items-center gap-3 text-blue-700">
                    <i class="fa-solid fa-magnifying-glass-chart text-xl"></i>
                    <h4 class="font-bold text-[15px] text-gray-900">Condition</h4>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed font-medium">All hardware condition (New/Used/Refurbished) is explicitly stated. Used parts are fully tested.</p>
            </div>
            <div class="space-y-4">
                <div class="flex items-center gap-3 text-blue-700">
                    <i class="fa-solid fa-shield-halved text-xl"></i>
                    <h4 class="font-bold text-[15px] text-gray-900">Warranty</h4>
                </div>
                <ul class="text-xs text-gray-500 space-y-2 font-medium">
                    <li>• New: 1-Year Warranty</li>
                    <li>• Used: 3-Month Warranty</li>
                    <li>• 14-Day Defect Returns</li>
                </ul>
            </div>
            <div class="space-y-4">
                <div class="flex items-center gap-3 text-blue-700">
                    <i class="fa-solid fa-truck-fast text-xl"></i>
                    <h4 class="font-bold text-[15px] text-gray-900">Shipping</h4>
                </div>
                <p class="text-xs text-gray-500 leading-relaxed font-medium">Global express (DHL/FedEx/UPS). Duty and import fees are the responsibility of the buyer.</p>
            </div>
        </div>
    </section>

    <section class="mt-32">
        <h2 class="text-[14px] font-bold text-blue-800 text-center uppercase tracking-[0.3em] mb-16">Related Modules</h2>
        {relatedItems.length > 0 ? (
          <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
              {relatedItems.map(item => (
                  <div class="group bg-white rounded-2xl border border-gray-100 p-5 hover:shadow-xl transition-all duration-500">
                      <a href={`/products/${item.data.brand.toLowerCase()}/${item.data.pn}`}>
                          <div class="aspect-square bg-gray-50 rounded-xl mb-6 overflow-hidden flex items-center justify-center p-6">
                              <img src={`/images/products/${item.data.brand.toLowerCase()}/${item.data.pn}.jpg`} class="w-full h-auto group-hover:scale-110 transition-transform duration-700" onerror="this.src='https://placehold.co/400x400?text=SFP'" />
                          </div>
                          <span class="text-[10px] font-bold text-blue-700 uppercase mb-2 block tracking-widest">{item.data.brand}</span>
                          <h3 class="font-extrabold text-gray-900 mb-1 group-hover:text-blue-700 transition-colors line-clamp-1">{item.data.pn}</h3>
                          <p class="text-[11px] text-gray-400 font-medium mb-4 line-clamp-1">{item.data.model}</p>
                          <div class="text-lg font-extrabold text-red-600 mb-6">US$ {item.data.price}</div>
                          <div class="inline-flex items-center gap-2 text-[11px] font-bold text-gray-900 group-hover:gap-4 transition-all">VIEW MORE <i class="fa-solid fa-arrow-right"></i></div>
                      </a>
                  </div>
              ))}
          </div>
        ) : (
          <p class="text-center text-gray-400 text-sm">More modules coming soon...</p>
        )}
    </section>
  </main>
</Layout>
