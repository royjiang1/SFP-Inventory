---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(entry => {
    // 自动从 slug 中提取 brand (文件夹名) 和 slug (文件名)
    const parts = entry.slug.split('/');
    const brand = parts[0];
    const slug = parts[1] || parts[0]; 
    return {
      params: { brand: brand.toLowerCase(), slug: slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);

// 关键修正：匹配你的实际路径 /images/products/[brand]/[pn].jpg
const brandPath = data.brand.toLowerCase();
const imagePath = `/images/products/${brandPath}/${data.pn}.jpg`;

const whatsappNumber = "+8617722444464";
const whatsappLink = `https://wa.me/${whatsappNumber}?text=Inquiry%20about%20${data.brand}%20${data.pn}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{data.brand} {data.pn} - H-COM</title>
    
    <script src="https://cdn.tailwindcss.com"></script>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Poppins', 'sans-serif'] }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Poppins', sans-serif; }
        .prose p { margin-bottom: 1em; color: #4B5563; line-height: 1.6; font-size: 0.875rem; }
    </style>
</head>

<body class="bg-gray-50 text-gray-900 antialiased">
    <nav class="bg-white border-b border-gray-100 px-6 py-4 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-black text-blue-600 tracking-tighter">H-COM</a>
            <div class="flex gap-6 text-[11px] font-bold text-gray-400 uppercase tracking-widest">
                <a href="/" class="hover:text-blue-600 transition">Home</a>
                <a href="#" class="text-blue-600">{data.brand}</a>
            </div>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 py-12">
        <div class="grid md:grid-cols-12 gap-12">
            <div class="md:col-span-7">
                <div class="bg-white p-4 rounded-[2rem] shadow-sm border border-gray-100 group">
                    <img 
                        src={imagePath} 
                        alt={data.model} 
                        class="w-full h-auto rounded-[1.5rem] transition-transform duration-500 group-hover:scale-[1.02]" 
                        onerror="this.src='https://placehold.co/800x600?text=Image+Not+Found'"
                    />
                </div>
            </div>

            <div class="md:col-span-5">
                <div class="mb-6">
                    <span class="px-3 py-1 bg-amber-50 text-amber-600 text-[10px] font-black rounded-full border border-amber-100 uppercase tracking-tighter">
                        {data.condition || "Used - Tested"}
                    </span>
                </div>

                <h1 class="text-4xl font-bold text-gray-900 leading-tight tracking-tight">
                    {data.brand} <br/> <span class="text-blue-600">{data.model}</span>
                </h1>
                
                <p class="text-sm font-bold text-gray-400 mt-4 uppercase tracking-widest">Part Number: {data.pn}</p>
                
                <div class="mt-8 flex items-baseline gap-2">
                    <span class="text-4xl font-black text-red-600">${data.price}</span>
                    <span class="text-gray-400 text-sm font-medium">/ unit</span>
                </div>

                <div class="grid grid-cols-2 gap-3 mt-8">
                    <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-black tracking-widest mb-1">Speed</p>
                        <p class="text-sm font-bold text-gray-800">{data.speed || '--'}</p>
                    </div>
                    <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-black tracking-widest mb-1">Reach</p>
                        <p class="text-sm font-bold text-gray-800">{data.reach || '--'}</p>
                    </div>
                    <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-black tracking-widest mb-1">Wavelength</p>
                        <p class="text-sm font-bold text-gray-800">{data.wavelength || '--'}</p>
                    </div>
                    <div class="bg-white p-4 rounded-2xl border border-gray-100 shadow-sm">
                        <p class="text-[9px] text-gray-400 uppercase font-black tracking-widest mb-1">Connector</p>
                        <p class="text-sm font-bold text-gray-800">{data.connector || '--'}</p>
                    </div>
                </div>

                <div class="mt-12 pt-8 border-t border-gray-100 prose">
                    <div class="text-[11px] font-black text-gray-900 uppercase tracking-[0.2em] mb-4 flex items-center gap-2">
                        <span class="w-8 h-[2px] bg-blue-600"></span> Description
                    </div>
                    <Content />
                </div>

                <div class="mt-10 space-y-3">
                    <a href={whatsappLink} target="_blank" class="flex items-center justify-center gap-3 w-full bg-[#25D366] text-white py-4 rounded-2xl font-bold hover:bg-[#20bd5a] transition-all shadow-lg shadow-green-100 group">
                        <span class="text-lg">Inquiry via WhatsApp</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="currentColor" viewBox="0 0 24 24"><path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766 0-3.18-2.587-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.747-2.874-2.512-2.96-2.626-.087-.115-.708-.941-.708-1.793 0-.852.449-1.273.608-1.441.159-.169.346-.21.463-.21s.233.001.334.005c.106.005.249-.04.391.302.144.35.493 1.203.536 1.29.044.086.073.186.015.301-.058.115-.088.19-.175.291-.086.1-.181.223-.259.3-.086.086-.176.18-.076.352.1.173.447.736.959 1.192.658.587 1.213.769 1.385.856.173.086.273.072.373-.044.1-.115.446-.517.561-.689.115-.172.23-.144.388-.086.158.058 1.006.474 1.179.56s.287.129.331.201c.044.072.044.416-.1.821z"/></svg>
                    </a>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
